[Desktop Entry]
Type=Application
Name=agentglass
GenericName=Agent Mission Control
Comment=Mission Control for AI coding agents — cost, tokens, diffs, git, terminal
# Launching plain covers every project; passing a directory scopes the window
# to that one. %f lets a file manager hand one over ("Open with agentglass"),
# which is why inode/directory is declared.
Exec=%%EXEC%% %f
Icon=agentglass
Terminal=false
Categories=Development;Monitor;
Keywords=agent;claude;observability;dashboard;git;
MimeType=inode/directory;
StartupWMClass=agentglass
